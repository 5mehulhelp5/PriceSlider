<?php
/** @var \WB\PriceSlider\Block\Slider $block */

$displayMin      = $block->getDisplayMinPrice();
$displayMax      = $block->getDisplayMaxPrice();
$selectedDispMin = $block->getSelectedDisplayMin();
$selectedDispMax = $block->getSelectedDisplayMax();
$baseMin         = $block->getBaseMinPrice();
$baseMax         = $block->getBaseMaxPrice();
$selectedBaseMin = $block->getSelectedBaseMin();
$selectedBaseMax = $block->getSelectedBaseMax();
$symbol          = $block->escapeHtml($block->getCurrencySymbol());
$rate            = $block->getCurrencyRate();
$step            = $block->getSliderStep();
$isActive        = $block->isPriceFilterActive();

// Raw integers for data-* attributes (JS reads these as numbers)
$fmtDispMin      = (int)floor($displayMin);
$fmtDispMax      = (int)ceil($displayMax);
$fmtSelMin       = (int)floor($selectedDispMin);
$fmtSelMax       = (int)ceil($selectedDispMax);
$fmtBaseMin      = (int)floor($baseMin);
$fmtBaseMax      = (int)ceil($baseMax);
$fmtSelBaseMin   = (int)floor($selectedBaseMin);
$fmtSelBaseMax   = (int)ceil($selectedBaseMax);

// Formatted strings for display (thousand-separated, matches JS toLocaleString output)
$displaySelMin   = number_format($fmtSelMin);
$displaySelMax   = number_format($fmtSelMax);
$displayRangeMin = number_format($fmtDispMin);
$displayRangeMax = number_format($fmtDispMax);
?>

<div class="wb-price-slider-wrap"
     data-display-min="<?= $fmtDispMin ?>"
     data-display-max="<?= $fmtDispMax ?>"
     data-selected-min="<?= $fmtSelMin ?>"
     data-selected-max="<?= $fmtSelMax ?>"
     data-base-min="<?= $fmtBaseMin ?>"
     data-base-max="<?= $fmtBaseMax ?>"
     data-selected-base-min="<?= $fmtSelBaseMin ?>"
     data-selected-base-max="<?= $fmtSelBaseMax ?>"
     data-currency-rate="<?= (float)$rate ?>"
     data-currency-symbol="<?= $symbol ?>"
     data-step="<?= (int)$step ?>">

    <div class="wb-ps-header">
        <strong class="wb-ps-title"><?= __('Filter By Price') ?></strong>
        <?php if ($isActive): ?>
        <a href="#" class="wb-ps-clear-link" title="<?= $block->escapeHtmlAttr(__('Clear price filter')) ?>">
            <?= __('Clear') ?>
        </a>
        <?php endif; ?>
    </div>

    <!-- Selected price range display -->
    <div class="wb-ps-amounts">
        <span class="wb-ps-min-amount">
            <span class="wb-ps-symbol"><?= $symbol ?></span><span class="wb-ps-min-val"><?= $displaySelMin ?></span>
        </span>
        <span class="wb-ps-separator">–</span>
        <span class="wb-ps-max-amount">
            <span class="wb-ps-symbol"><?= $symbol ?></span><span class="wb-ps-max-val"><?= $displaySelMax ?></span>
        </span>
    </div>

    <!-- jQuery UI slider track -->
    <div id="wb-price-slider" class="wb-ps-slider"></div>

    <!-- Full category range — gives users scale context while dragging -->
    <div class="wb-ps-range-labels">
        <span><?= $symbol ?>&nbsp;<?= $displayRangeMin ?></span>
        <span><?= $symbol ?>&nbsp;<?= $displayRangeMax ?></span>
    </div>

    <!-- Apply button -->
    <div class="wb-ps-actions">
        <button type="button" class="wb-ps-apply action primary" title="<?= $block->escapeHtmlAttr(__('Apply filter')) ?>">
            <?= __('Apply') ?>
        </button>
    </div>
</div>

<script type="text/x-magento-init">
{
    ".wb-price-slider-wrap": {
        "WB_PriceSlider/js/price-slider": {}
    }
}
</script>
