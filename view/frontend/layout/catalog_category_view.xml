<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- Load price-slider CSS from the module's web/css directory -->
        <css src="WB_PriceSlider::css/price-slider.css"/>
    </head>
    <body>
        <referenceContainer name="sidebar.main">
            <block class="WB\PriceSlider\Block\Slider"
                   name="wb.price.slider"
                   template="WB_PriceSlider::slider.phtml"
                   after="catalog.leftnav"/>
        </referenceContainer>
    </body>
</page>
